rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own doc and their own tasks.
    // Anonymous auth gives each device a stable uid, so this keeps
    // everyone's data isolated.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
